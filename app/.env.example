# Frontend (Vite) build-time configuration. Copy to .env for local dev.

# API base. Empty / unset = same origin (recommended: the single binary serves
# both the app and the API). Set when the app and API are on different domains.
# VITE_API_URL=https://api.openbeehive.org

# Marketing site base. When set, Settings links to its legal pages
# (e.g. https://openbeehive.org/imprint). Leave unset for pure self-host.
# VITE_MARKETING_URL=https://openbeehive.org
