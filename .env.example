# ============================================================================
# Openbeehive server configuration. Every runtime value the server uses is read
# from the environment (see server/internal/config). Copy to .env and adjust.
# Defaults shown are the built-in defaults; commented lines are optional.
# ============================================================================

# ===== Deployment profile =====
# selfhost => SQLite + filesystem (single binary, no Docker needed)
# cloud    => PostgreSQL + MinIO
BEEHIVE_DEPLOYMENT_PROFILE=selfhost

# ===== HTTP server =====
BEEHIVE_ADDR=:8080
BEEHIVE_PUBLIC_BASE_URL=http://localhost:8080
# BEEHIVE_HTTP_READ_HEADER_TIMEOUT=10s
# BEEHIVE_HTTP_READ_TIMEOUT=0          # 0 = no limit (needed for streaming/Subscribe)
# BEEHIVE_HTTP_WRITE_TIMEOUT=0
# BEEHIVE_HTTP_IDLE_TIMEOUT=120s
# BEEHIVE_HTTP_SHUTDOWN_TIMEOUT=15s

# ===== Embedded web app =====
BEEHIVE_SERVE_WEB=true                 # serve the embedded SPA (single-binary production)
# BEEHIVE_WEB_DIR=                     # serve this dir instead of the embedded build

# ===== CORS (browser clients; needed for cross-origin app domains) =====
BEEHIVE_CORS_ALLOWED_ORIGINS=*         # comma-separated; e.g. https://app.openbeehive.org
BEEHIVE_CORS_ALLOW_CREDENTIALS=true

# ===== Sync =====
BEEHIVE_NODE_ID=server                 # HLC node id stamped on server-side changes

# ===== Database (overrides the profile default) =====
# BEEHIVE_DATABASE_DRIVER=postgres|mysql|sqlite
# BEEHIVE_DATABASE_DSN=postgres://user:pass@host:5432/db?sslmode=disable
# BEEHIVE_DATABASE_DSN=user:pass@tcp(host:3306)/openbeehive?parseTime=true   # MySQL
# BEEHIVE_DATABASE_DSN=file:openbeehive.db?_pragma=journal_mode(WAL)         # SQLite

# ===== Blob storage =====
# BEEHIVE_BLOB_BACKEND=minio|fs
BEEHIVE_BLOB_DIR=./data/blobs
BEEHIVE_MINIO_ENDPOINT=localhost:9000
BEEHIVE_MINIO_ACCESS_KEY=minioadmin
BEEHIVE_MINIO_SECRET_KEY=minioadmin
BEEHIVE_MINIO_BUCKET=openbeehive
BEEHIVE_MINIO_USE_SSL=false

# ===== Auth: app session =====
# Required once any login method is enabled, so sessions survive restarts.
# Generate: openssl rand -base64 32
BEEHIVE_SESSION_SECRET=
# BEEHIVE_SESSION_TTL=720h

# ===== Auth: WebAuthn / passkeys =====
BEEHIVE_WEBAUTHN_ENABLED=false
# BEEHIVE_WEBAUTHN_RP_ID=openbeehive.org                 # effective domain (default: host of PUBLIC_BASE_URL)
# BEEHIVE_WEBAUTHN_RP_ORIGINS=https://app.openbeehive.org # comma-separated allowed origins
# BEEHIVE_WEBAUTHN_RP_DISPLAY_NAME=Openbeehive

# ===== Auth: OIDC (multiple providers, comma-separated) =====
# Leave BEEHIVE_OIDC_PROVIDERS empty AND BEEHIVE_WEBAUTHN_ENABLED=false for self-host single-user
# mode (no login required). Set to enable login, e.g. BEEHIVE_OIDC_PROVIDERS=google,keycloak
BEEHIVE_OIDC_PROVIDERS=
BEEHIVE_OIDC_REDIRECT_URL=http://localhost:8080/auth/callback

BEEHIVE_OIDC_GOOGLE_ISSUER=https://accounts.google.com
BEEHIVE_OIDC_GOOGLE_CLIENT_ID=
BEEHIVE_OIDC_GOOGLE_CLIENT_SECRET=
# BEEHIVE_OIDC_GOOGLE_SCOPES=openid,profile,email

# Self-hosted IdP (Keycloak/Authentik)
BEEHIVE_OIDC_KEYCLOAK_ISSUER=https://id.example.com/realms/openbeehive
BEEHIVE_OIDC_KEYCLOAK_CLIENT_ID=openbeehive
BEEHIVE_OIDC_KEYCLOAK_CLIENT_SECRET=

# ===== Onboarding: email + password (in-app users) =====
# Multi-user accounts without OIDC. First account created on a fresh instance
# becomes the admin. Defaults: on for cloud, off for selfhost (single-user).
# BEEHIVE_PASSWORD_AUTH=true
# Open self-registration. false = invite-only: beyond the first-run admin,
# accounts can only be created via invite links; the login screen shows an
# invite-only banner. Existing accounts sign in normally.
# BEEHIVE_REGISTRATION=true
# Require email verification before first sign-in (optional).
BEEHIVE_EMAIL_VERIFICATION=false
# SMTP for verification/invite emails. If unset, links are logged instead.
# BEEHIVE_SMTP_HOST=
# BEEHIVE_SMTP_PORT=587
# BEEHIVE_SMTP_USER=
# BEEHIVE_SMTP_PASS=
# BEEHIVE_SMTP_FROM=Openbeehive <no-reply@openbeehive.org>

# ===== Demo tenant (showcase) =====
# Installs a demo account + tenant (15 hives, 4 apiaries), reset hourly. OFF by
# default. Enabling it implies BEEHIVE_PASSWORD_AUTH=true.
BEEHIVE_DEMO=false
# BEEHIVE_DEMO_EMAIL=demo@app.openbeehive.org
# BEEHIVE_DEMO_PASSWORD=demo
